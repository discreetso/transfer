     1                                  ; Let's run a 32-bit program in Ubuntu! 
     2                                  
     3                                  ; Install NASM in Ubuntu: 
     4                                  ; sudo apt install nasm
     5                                  
     6                                  ; Create this code file 
     7                                  
     8                                  ; Assemble: 
     9                                  ;   nasm -f elf32 -l coal12.lst -o coal12.o coal12.asm
    10                                  
    11                                  ; 	We want to create a format that Linux understand
    12                                  ;	i.e. ELF format in 32-bits 
    13                                  ; 	(we also create a listing file)
    14                                  ;   Read more about ELF here: https://linux-audit.com/elf-binaries-on-linux-understanding-and-analysis/ 
    15                                  
    16                                  ; Link with shared library that 'understands' the format: ld.so in Linux 
    17                                  ;       ld -m elf_i386 -o coal12 coal12.o
    18                                  
    19                                  ; run it:
    20                                  ;    ./coal12
    21                                  
    22                                  ; Now let's discuss the code! 
    23                                  
    24                                  ; in modern OSs, programs do not start executing 
    25                                  ; "from the first instruction"
    26                                  
    27                                  ; Instead, there is a library (ld.so) that looks for the "start symbol"
    28                                  ; and executes from there. 
    29                                  
    30                                  
    31                                  
    32                                  
    33                                  
    34                                  
    35                                  
    36                                  
    37                                  ; a section 'directive' marks the part of a program 
    38                                  ; for the ELF format (or whatever binary format you are using)
    39                                  
    40                                  SECTION .text
    41                                  
    42                                  ; we mark the start of this library using the following:
    43                                  GLOBAL _start
    44                                  
    45                                  _start:
    46                                  
    47                                      ; write the string to console
    48 00000000 B804000000                  mov eax, 0x4                    ; write syscall is 0x4
    49 00000005 BB01000000                  mov ebx, 1                      ; param -std output should be used
    50 0000000A B9[00000000]                mov ecx, message                ; the string to write
    51 0000000F BA08000000                  mov edx, message_length         ; the length of the string
    52 00000014 CD80                        int 0x80                        ; invoke the system call 
    53                                  
    54                                      ; exit the program
    55 00000016 B801000000                  mov eax, 0x1                    ; exit system call is 0x1
    56 0000001B BB00000000                  mov ebx, 0                      ; exit code is 0 (like c/c++, return 0)
    57 00000020 CD80                        int 0x80                        ; comment out and see
    58                                  ; note that int is NOT the right way to do things! (more on this later)
    59                                  
    60                                  ; data section here. We can also move it above .code
    61                                  SECTION .data
    62                                  
    63                                  ; 0xA is new line, 0x0 is null terminator
    64 00000000 48656C6C6F210A00        message: db "Hello!", 0xA, 0x0
    65                                  message_length: equ $-message
    66                                  ; message_length: equ 8 
    67                                  ; .... is exactly the same as
    68                                  ; #define message_length 8
